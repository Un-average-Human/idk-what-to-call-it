; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="airship system"
run/main_scene="uid://d15rnpjif8qxh"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SignalBus="*uid://x8w6hewa23gf"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg", "res://addons/godotsteam/plugin.cfg")

[file_customization]

folder_colors={
"res://models/": "red",
"res://models/airship_models/": "red",
"res://player/": "blue",
"res://resources/": "purple",
"res://scenes/": "green",
"res://scripts/": "orange",
"res://scripts/airship_scripts/": "orange",
"res://scripts/autoloads/": "orange",
"res://scripts/delivery_scripts/": "orange"
}

